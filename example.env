# GMID Music Bot - Example .env file
# Fill in your own values and rename this file to .env

# Your Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_token_here

# OpenAI API Key (for lyrics/query refinement - optional)
OPENAI_API_KEY=your_openai_key_here

# Genius API Token (for lyrics - optional)
GENIUS_ACCESS_TOKEN=your_genius_token_here
